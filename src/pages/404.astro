---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Seite nicht gefunden | Zoko Bauunternehmen"
  description="Die angeforderte Seite konnte nicht gefunden werden."
>
  <main id="main-content" class="flex min-h-[60vh] items-center justify-center px-4 py-20">
    <div class="text-center">
      <h1 class="text-6xl font-bold text-primary">404</h1>
      <h2 class="mt-4 text-2xl font-semibold text-dark">Seite nicht gefunden</h2>
      <p class="mt-2 text-dark/70">Die angeforderte Seite existiert nicht.</p>
      <a href="/" class="btn-primary mt-6 inline-block">Zur Startseite</a>
    </div>
  </main>
</Layout>
