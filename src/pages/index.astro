---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import WhyUs from '../components/WhyUs.astro';
import Services from '../components/Services.astro';
import About from '../components/About.astro';
import Projects from '../components/Projects.astro';
import Testimonials from '../components/Testimonials.astro';
import Contact from '../components/Contact.astro';
---

<Layout
  title="Zoko Bauunternehmen | Handwerker Karlsruhe - Renovierung, Trockenbau & Malerarbeiten"
  description="Zoko Bauunternehmen – Ihr zuverlässiger Handwerker in Karlsruhe für Renovierung, Trockenbau, Badsanierung, Malerarbeiten, Entrümpelung & Umzüge. Zoran Jovic: persönlich, professionell, aus Karlsruhe. Jetzt Beratung anfragen!"
>
  <main id="main-content">
    <Hero />
    <WhyUs />
    <Services />
    <About />
    <Projects />
    <Testimonials />
    <Contact />
  </main>
</Layout>
