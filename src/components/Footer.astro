---
import logoImg from '../assets/logo.jpeg';

const currentYear = new Date().getFullYear();
---

<footer class="bg-dark text-white/80">
  <div class="mx-auto max-w-7xl px-4 py-12 sm:px-6 lg:px-8">
    <div class="flex flex-col items-center justify-between gap-6 md:flex-row">
      <div class="text-center md:text-left">
        <a href="/" class="inline-flex items-center justify-center" aria-label="Zoko Bauunternehmen - Zur Startseite">
          <img
            src={logoImg.src}
            alt="Zoko Bauunternehmen Logo"
            width="128"
            height="64"
            class="h-16 w-auto object-contain"
            loading="lazy"
            decoding="async"
          />
        </a>
        <p class="mt-1 text-sm text-white/80">Inhaber: Zoran Jovic</p>
        <p class="mt-1 text-sm text-white/80">Marienstr. 61, 76137 Karlsruhe</p>
        <p class="mt-1 text-sm text-white/80">
          <a href="tel:+4915756463902" class="hover:text-primary hover:underline transition-colors">+49 157 56463902</a> | 
          <a href="tel:+4917647314186" class="hover:text-primary hover:underline transition-colors">+49 176 47314186</a>
        </p>
      </div>

      <div class="flex flex-col items-center gap-4 md:items-end">
        <div class="flex flex-wrap justify-center gap-6 text-sm font-medium">
          <a href="/impressum" class="text-white/80 hover:text-primary transition-colors duration-300">Impressum</a>
          <a href="/datenschutz" class="text-white/80 hover:text-primary transition-colors duration-300">Datenschutz</a>
        </div>
        <p class="text-xs text-white/60">
          &copy; {currentYear} Zoko Bauunternehmen. Alle Rechte vorbehalten.
        </p>
      </div>
    </div>
  </div>
</footer>
