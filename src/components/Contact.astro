---
const web3formsKey = import.meta.env.PUBLIC_WEB3FORMS_KEY;
---

<section id="kontakt" class="bg-light py-20 sm:py-24" aria-labelledby="contact-heading">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="grid gap-12 lg:grid-cols-2 lg:gap-16">
      
      <!-- Contact Info -->
      <div>
        <h2 id="contact-heading" class="text-3xl font-bold text-dark sm:text-4xl">
          Lassen Sie uns Ihr Projekt besprechen
        </h2>
        <p class="mt-4 text-dark/70">
          Ob Neubau, Renovierung oder Sanierung – wir beraten Sie persönlich und unverbindlich. Kontaktieren Sie Zoran Jovic direkt.
        </p>

        <div class="mt-8 space-y-5">
          <div>
            <p class="text-sm font-medium text-dark/60">Inhaber</p>
            <p class="text-lg font-semibold text-dark">Zoran Jovic</p>
          </div>
          <div>
            <p class="text-sm font-medium text-dark/60">Adresse</p>
            <p class="text-dark">Marienstr. 61<br />76137 Karlsruhe</p>
          </div>
          <div>
            <p class="text-sm font-medium text-dark/60">Telefon</p>
            <p class="text-lg font-semibold text-dark">
              <a href="tel:+4915756463902" class="text-primary hover:underline">+49 157 56463902</a>
            </p>
            <p class="text-lg font-semibold text-dark">
              <a href="tel:+4917647314186" class="text-primary hover:underline">+49 176 47314186</a>
            </p>
          </div>
          <div>
            <p class="text-sm font-medium text-dark/60">E-Mail</p>
            <p class="text-dark">
              <a href="mailto:kontakt@zoko-bauunternehmen.de" class="text-primary hover:underline">kontakt@zoko-bauunternehmen.de</a>
            </p>
          </div>

          <a
            href="https://wa.me/4915756463902"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 rounded bg-[#25D366] px-5 py-3 text-sm font-semibold text-white shadow hover:brightness-110 transition-all duration-300"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
            </svg>
            Jetzt per WhatsApp schreiben
          </a>
        </div>
      </div>

      <!-- Contact Form -->
      <div class="rounded-2xl border border-dark/10 bg-white p-6 shadow-sm sm:p-10">
        <form
          id="contact-form"
          action="https://api.web3forms.com/submit"
          method="POST"
          class="space-y-5"
          novalidate
        >
          <!-- Web3Forms Config -->
          <input type="hidden" name="access_key" value={web3formsKey} />
          <input type="hidden" name="subject" value="Neue Kontaktanfrage über zoko-bauunternehmen.de" />
          <input type="hidden" name="from_name" value="Zoko Bauunternehmen Website" />
          <input type="checkbox" name="botcheck" class="hidden" tabindex="-1" autocomplete="off" />

          <div>
            <label for="name" class="block text-sm font-medium text-dark">Name</label>
            <input
              type="text"
              id="name"
              name="name"
              required
              class="mt-1 block w-full rounded-md border border-dark/20 bg-white px-4 py-3 text-dark placeholder:text-dark/40 focus:border-primary focus:outline-none focus:ring-1 focus:ring-primary"
              placeholder="Ihr vollständiger Name"
            />
            <p class="mt-1 hidden text-sm text-red-600" id="name-error">Bitte geben Sie Ihren Namen ein.</p>
          </div>

          <div>
            <label for="email" class="block text-sm font-medium text-dark">E-Mail</label>
            <input
              type="email"
              id="email"
              name="email"
              required
              class="mt-1 block w-full rounded-md border border-dark/20 bg-white px-4 py-3 text-dark placeholder:text-dark/40 focus:border-primary focus:outline-none focus:ring-1 focus:ring-primary"
              placeholder="ihre@email.de"
            />
            <p class="mt-1 hidden text-sm text-red-600" id="email-error">Bitte geben Sie eine gültige E-Mail-Adresse ein.</p>
          </div>

          <div>
            <label for="phone" class="block text-sm font-medium text-dark">Telefon <span class="text-dark/50">(optional)</span></label>
            <input
              type="tel"
              id="phone"
              name="phone"
              class="mt-1 block w-full rounded-md border border-dark/20 bg-white px-4 py-3 text-dark placeholder:text-dark/40 focus:border-primary focus:outline-none focus:ring-1 focus:ring-primary"
              placeholder="+49 123 456789"
            />
          </div>

          <div>
            <label for="message" class="block text-sm font-medium text-dark">Nachricht</label>
            <textarea
              id="message"
              name="message"
              rows="4"
              required
              class="mt-1 block w-full rounded-md border border-dark/20 bg-white px-4 py-3 text-dark placeholder:text-dark/40 focus:border-primary focus:outline-none focus:ring-1 focus:ring-primary"
              placeholder="Beschreiben Sie kurz Ihr Projekt..."
            ></textarea>
            <p class="mt-1 hidden text-sm text-red-600" id="message-error">Bitte geben Sie eine Nachricht ein.</p>
          </div>

          <button type="submit" class="btn-primary w-full">
            Nachricht senden
          </button>

          <div id="form-success" class="hidden rounded-md bg-green-50 p-4 text-sm text-green-800" role="alert">
            Vielen Dank für Ihre Anfrage! Wir melden uns zeitnah bei Ihnen.
          </div>
          <div id="form-error" class="hidden rounded-md bg-red-50 p-4 text-sm text-red-800" role="alert">
            Leider ist ein Fehler aufgetreten. Bitte versuchen Sie es später erneut oder rufen Sie uns direkt an.
          </div>
        </form>
      </div>
    </div>
  </div>
</section>

<script>
  (function () {
    const form = document.getElementById('contact-form');
    if (!form) return;

    form.addEventListener('submit', async function (e) {
      e.preventDefault();

      const name = form.querySelector('#name');
      const email = form.querySelector('#email');
      const message = form.querySelector('#message');
      const success = document.getElementById('form-success');
      const error = document.getElementById('form-error');

      // Reset errors
      [name, email, message].forEach((el) => {
        if (el) {
          const err = document.getElementById(el.id + '-error');
          if (err) err.classList.add('hidden');
        }
      });
      if (success) success.classList.add('hidden');
      if (error) error.classList.add('hidden');

      let valid = true;

      if (!name?.value.trim()) {
        document.getElementById('name-error')?.classList.remove('hidden');
        valid = false;
      }

      const emailPattern = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
      if (!email?.value.trim() || !emailPattern.test(email.value.trim())) {
        document.getElementById('email-error')?.classList.remove('hidden');
        valid = false;
      }

      if (!message?.value.trim()) {
        document.getElementById('message-error')?.classList.remove('hidden');
        valid = false;
      }

      if (!valid) return;

      const formData = new FormData(form);
      try {
        const res = await fetch(form.action, {
          method: 'POST',
          body: formData,
        });
        const data = await res.json();
        if (data.success) {
          form.reset();
          success?.classList.remove('hidden');
        } else {
          error?.classList.remove('hidden');
        }
      } catch {
        error?.classList.remove('hidden');
      }
    });
  })();
</script>
