---
const reasons = [
  {
    title: 'Alles aus einer Hand',
    text: 'Von der Planung bis zur Fertigstellung – wir begleiten Ihr Projekt lückenlos und koordinieren alle Gewerke.',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-10 h-10"><path stroke-linecap="round" stroke-linejoin="round" d="M11.42 15.17 17.25 21A2.652 2.652 0 0 0 21 17.25l-5.877-5.877M11.42 15.17l2.496-3.03c.317-.384.74-.626 1.208-.766M11.42 15.17l-4.655 5.653a2.548 2.548 0 1 1-3.586-3.586l6.837-5.63m5.108-.233c.55-.164 1.163-.188 1.743-.14a4.5 4.5 0 0 0 4.486-6.336l-3.276 3.277a3.004 3.004 0 0 1-2.25-2.25l3.276-3.276a4.5 4.5 0 0 0-6.336 4.486c.091 1.076-.071 2.264-.904 2.95l-.003.002m-10.648 0a2.548 2.548 0 1 0 3.586 3.586l6.837-5.63m0 0a2.55 2.55 0 0 0 1.713-1.713" /></svg>`,
  },
  {
    title: 'Termintreue',
    text: 'Wir halten, was wir versprechen. Pünktliche Fertigstellung ist für uns eine Selbstverständlichkeit.',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-10 h-10"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" /></svg>`,
  },
  {
    title: 'Sauberkeit',
    text: 'Baustaub gehört nicht in Ihr Zuhause. Wir arbeiten ordentlich und räumen täglich auf.',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-10 h-10"><path stroke-linecap="round" stroke-linejoin="round" d="m14.74 9-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 0 1-2.244 2.077H8.084a2.25 2.25 0 0 1-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 0 0-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 0 1 3.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 0 0-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 0 0-7.5 0" /></svg>`,
  },
  {
    title: 'Regionale Expertise',
    text: 'Über 10 Jahre Erfahrung in Karlsruhe und Umgebung. Wir kennen die Region und ihre Besonderheiten.',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-10 h-10"><path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" /><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0Z" /></svg>`,
  },
];
---

<section class="bg-gray-50 py-20 sm:py-24" aria-labelledby="whyus-heading">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="text-center">
      <h2 id="whyus-heading" class="text-3xl font-bold text-dark sm:text-4xl">Warum Zoko Bauunternehmen?</h2>
      <p class="mx-auto mt-4 max-w-2xl text-dark/70">
        Was uns von anderen Bauunternehmen in Karlsruhe unterscheidet.
      </p>
    </div>

    <div class="mt-14 grid gap-8 sm:grid-cols-2 lg:grid-cols-4">
      {reasons.map((reason) => (
        <article class="flex flex-col items-center rounded-xl border border-gray-100 bg-white p-6 text-center shadow-sm transition-all duration-300 hover:-translate-y-1 hover:shadow-md">
          <div class="text-primary" set:html={reason.icon} />
          <h3 class="mt-4 text-lg font-semibold text-dark">{reason.title}</h3>
          <p class="mt-2 text-sm leading-relaxed text-dark/70">{reason.text}</p>
        </article>
      ))}
    </div>
  </div>
</section>
