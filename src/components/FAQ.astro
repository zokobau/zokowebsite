---
const faqs = [
  {
    question: 'Bieten Sie Komplettbäder an?',
    answer: 'Ja, absolut. Von der Demontage des alten Bades über Elektro- und Sanitärarbeiten bis hin zur finalen Fliesenverlegung übernehmen wir jeden Schritt. Sie erhalten Ihr Traumbad aus einer Hand.',
  },
  {
    question: 'Wie lange dauert eine Badsanierung?',
    answer: 'Je nach Umfang benötigen wir in der Regel 2 bis 4 Wochen. Bereits vor Projektstart erstellen wir einen transparenten Zeitplan, an den wir uns strikt halten.',
  },
  {
    question: 'Kommen Sie vorher zur Besichtigung?',
    answer: 'Selbstverständlich. Eine Vor-Ort-Besichtigung in Karlsruhe und Umgebung ist für uns die Basis für ein präzises, unverbindliches Angebot. Rufen Sie uns einfach an.',
  },
];
---

<section class="bg-gray-50 py-20 sm:py-24" aria-labelledby="faq-heading">
  <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
    <div class="text-center">
      <h2 id="faq-heading" class="text-3xl font-bold text-dark sm:text-4xl">Häufig gestellte Fragen</h2>
      <p class="mx-auto mt-4 text-dark/70">
        Schnelle Antworten auf die wichtigsten Fragen rund um Ihr Bauprojekt.
      </p>
    </div>

    <div class="mt-12 space-y-4">
      {faqs.map((faq) => (
        <details class="group rounded-lg border border-gray-100 bg-white p-6 shadow-sm transition-all open:border-primary/30 open:shadow-md">
          <summary class="flex cursor-pointer list-none items-center justify-between text-lg font-semibold text-dark focus:outline-none focus-visible:ring-2 focus-visible:ring-primary focus-visible:ring-offset-2">
            {faq.question}
            <span class="ml-4 flex h-8 w-8 flex-shrink-0 items-center justify-center rounded-full bg-gray-100 text-dark transition-colors group-open:bg-primary group-open:text-dark">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
              </svg>
            </span>
          </summary>
          <p class="mt-4 leading-relaxed text-dark/70">
            {faq.answer}
          </p>
        </details>
      ))}
    </div>
  </div>
</section>
