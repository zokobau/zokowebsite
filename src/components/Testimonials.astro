---
import { Image } from 'astro:assets';
import imgKunde1 from '../assets/kunde1.jpg';
import imgKunde2 from '../assets/kunde2.jpg';
import imgKunde3 from '../assets/kunde3.jpg';

const testimonials = [
  {
    name: 'Max M.',
    location: 'Karlsruhe',
    quote: 'Herr Jovic hat unser Bad komplett saniert. Termintreue, Sauberkeit und das Ergebnis waren erstklassig. Absolute Empfehlung!',
    image: imgKunde1,
    alt: 'Fertig saniertes Badezimmer in Karlsruhe',
  },
  {
    name: 'Familie K.',
    location: 'Durlach',
    quote: 'Der Innenausbau unseres Altbaus wurde perfekt umgesetzt. Zoko Bauunternehmen arbeitet professionell und zu fairen Preisen.',
    image: imgKunde2,
    alt: 'Innenausbau und Renovierung eines Wohnraums',
  },
  {
    name: 'Stefan B.',
    location: 'Karlsruhe-West',
    quote: 'Von der ersten Beratung bis zur finalen Fliesenverlegung – alles lief reibungslos. Wir sind begeistert vom neuen Wohnzimmer.',
    image: imgKunde3,
    alt: 'Professionelle Fliesenarbeiten im Wohnzimmer',
  },
];
---

<section class="bg-dark py-20 sm:py-24" aria-labelledby="testimonials-heading">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="text-center">
      <h2 id="testimonials-heading" class="text-3xl font-bold text-white sm:text-4xl">Was unsere Kunden in Karlsruhe sagen</h2>
      <p class="mx-auto mt-4 max-w-2xl text-white/70">
        Vertrauen ist das Fundament jedes Bauprojekts. Lesen Sie, was unsere Auftraggeber über die Zusammenarbeit sagen.
      </p>
    </div>

    <div class="mt-14 grid gap-8 sm:grid-cols-2 lg:grid-cols-3">
      {testimonials.map((t) => (
        <article class="flex flex-col overflow-hidden rounded-xl border border-white/10 bg-white/5 backdrop-blur-sm">
          <!-- Großes Projekt-Bild -->
          <div class="aspect-[16/10] w-full overflow-hidden">
            <Image
              src={t.image}
              alt={t.alt}
              width={800}
              height={500}
              loading="lazy"
              class="h-full w-full object-cover"
            />
          </div>

          <div class="flex flex-1 flex-col p-8">
            <!-- Stars -->
            <div class="flex gap-1" aria-label="5 von 5 Sternen">
              {Array.from({ length: 5 }).map(() => (
                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 fill-primary text-primary" viewBox="0 0 20 20" aria-hidden="true">
                  <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
                </svg>
              ))}
            </div>

            <!-- Quote -->
            <blockquote class="mt-4 flex-1 leading-relaxed text-white/90">
              "{t.quote}"
            </blockquote>

            <!-- Author -->
            <footer class="mt-6 border-t border-white/10 pt-6">
              <p class="font-semibold text-white">{t.name}</p>
              <p class="text-sm text-primary">{t.location}</p>
            </footer>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>
