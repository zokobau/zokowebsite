<div
  id="cookie-banner"
  class="fixed bottom-0 left-0 right-0 z-[60] hidden border-t border-dark/10 bg-light/95 p-4 shadow-2xl backdrop-blur md:bottom-6 md:left-6 md:right-auto md:max-w-sm md:rounded-xl md:border"
  role="dialog"
  aria-live="polite"
  aria-label="Cookie-Einwilligung"
>
  <div class="flex flex-col gap-4">
    <div>
      <h3 class="text-sm font-semibold text-dark">Datenschutz-Einstellungen</h3>
      <p class="mt-1 text-sm leading-relaxed text-dark/80">
        Wir verwenden nur technisch notwendige Cookies. Externes Tracking oder Analyse-Tools werden ohne Ihre ausdrückliche Einwilligung nicht aktiviert.
      </p>
    </div>
    <div class="flex flex-wrap items-center gap-2">
      <button
        id="cookie-accept"
        class="btn-primary px-4 py-2 text-sm"
        type="button"
      >
        Alle akzeptieren
      </button>
      <button
        id="cookie-deny"
        class="inline-flex items-center justify-center rounded px-4 py-2 text-sm font-medium text-dark hover:bg-dark/5 transition-colors"
        type="button"
      >
        Nur notwendige
      </button>
    </div>
  </div>
</div>

<script>
  (function () {
    const banner = document.getElementById('cookie-banner');
    const btnAccept = document.getElementById('cookie-accept');
    const btnDeny = document.getElementById('cookie-deny');
    const STORAGE_KEY = 'zoko_cookie_consent';

    if (!banner) return;

    const consent = localStorage.getItem(STORAGE_KEY);
    if (!consent) {
      banner.classList.remove('hidden');
    }

    function setConsent(value) {
      localStorage.setItem(STORAGE_KEY, value);
      banner.classList.add('hidden');
      // Opt-in Logik für zukünftiges Tracking
      if (value === 'accepted') {
        // window.dispatchEvent(new CustomEvent('cookie-consent-accepted'));
      }
    }

    btnAccept?.addEventListener('click', () => setConsent('accepted'));
    btnDeny?.addEventListener('click', () => setConsent('denied'));
  })();
</script>
